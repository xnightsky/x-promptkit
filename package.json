{
  "name": "x-promptkit",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "npm run lint:code && npm run lint:docs && npm run lint:repo",
    "lint:code": "node scripts/tooling/lint-code.mjs",
    "lint:docs": "node scripts/tooling/lint-docs.mjs",
    "lint:repo": "node scripts/tooling/lint-repo.mjs",
    "check": "npm run check:fixtures",
    "check:fixtures": "node scripts/tooling/check-fixtures.mjs",
    "verify": "npm run lint && npm run check && npm test",
    "guided-review": "node skills/guided-review/scripts/run-review.mjs",
    "test": "node --test",
    "test:recall-unit": "node --test tests/recall-eval.lib.test.mjs",
    "test:recall-bridge": "node --test tests/recall-eval.carrier-adapter.test.mjs",
    "test:recall-cli": "node --test tests/recall-eval.test.mjs",
    "test:recall-harness": "node --test tests/recall-eval.iitest-lib.test.mjs tests/recall-eval.iitest-runner.test.mjs",
    "recall:iitest": "node scripts/recall-eval/run-iitest.mjs",
    "recall:validate": "node scripts/recall-eval/validate-schema.mjs",
    "recall:resolve": "node scripts/recall-eval/resolve-target.mjs",
    "recall:run": "node scripts/recall-eval/run-eval.mjs"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
