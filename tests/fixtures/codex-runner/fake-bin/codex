#!/usr/bin/env node

import fs from "node:fs";
import path from "node:path";
import process from "node:process";
import { fileURLToPath } from "node:url";

const mode = process.env.CODEX_FIXTURE_MODE ?? "probe_ok";
const args = process.argv.slice(2);
const fixtureFilePath = fileURLToPath(import.meta.url);
const eventsDir = path.resolve(path.dirname(fixtureFilePath), "..", "events");

function writeFileFixture(fileName) {
  process.stdout.write(fs.readFileSync(path.join(eventsDir, fileName), "utf8"));
}

function writeTurnCompleted(finalText) {
  process.stdout.write(`{"type":"thread.started","thread_id":"fixture-thread"}\n`);
  process.stdout.write(`{"type":"turn.started"}\n`);
  process.stdout.write(
    `${JSON.stringify({ type: "turn.completed", status: "completed", result: { final_text: finalText, refusal: false } })}\n`,
  );
}

if (args[0] === "--version") {
  if (mode === "version_probe_failed") {
    process.stderr.write("version probe failed\n");
    process.exit(1);
  }

  process.stdout.write("codex-fixture 1.2.3\n");
  process.exit(0);
}

if (args[0] === "exec" && args[1] === "--help") {
  if (mode === "exec_missing") {
    process.stderr.write("unknown subcommand: exec\n");
    process.exit(1);
  }

  if (mode === "json_flag_missing") {
    process.stdout.write("Usage: codex exec <prompt>\n");
    process.exit(0);
  }

  process.stdout.write("Usage: codex exec --json <prompt>\n  --json  emit jsonl events\n");
  process.exit(0);
}

if (args[0] === "exec" && args[1] === "--json") {
  if (mode === "run_skill_view_check") {
    const skillPath = path.join(process.env.HOME ?? "", ".agents", "skills", "demo-skill", "SKILL.md");
    if (!fs.existsSync(skillPath)) {
      process.stderr.write(`missing skill view: ${skillPath}\n`);
      process.exit(1);
    }

    const skillText = fs.readFileSync(skillPath, "utf8");
    if (!skillText.includes("# demo")) {
      process.stderr.write("unexpected skill contents\n");
      process.exit(1);
    }

    writeTurnCompleted("skill view ok");
    process.exit(0);
  }

  if (mode === "run_explicit_skill_allowlist_check") {
    const homeSkillsRoot = path.join(process.env.HOME ?? "", ".agents", "skills");
    const requiredSkills = ["isolated-context-run", "isolated-context-run-codex", "claude-p-watch"];

    for (const skillName of requiredSkills) {
      const skillPath = path.join(homeSkillsRoot, skillName, "SKILL.md");
      if (!fs.existsSync(skillPath)) {
        process.stderr.write(`missing skill view: ${skillPath}\n`);
        process.exit(1);
      }
    }

    const mountedSkills = fs.readdirSync(homeSkillsRoot).sort();
    if (JSON.stringify(mountedSkills) !== JSON.stringify([...requiredSkills].sort())) {
      process.stderr.write(`unexpected mounted skills: ${mountedSkills.join(",")}\n`);
      process.exit(1);
    }

    const watchSkillText = fs.readFileSync(
      path.join(homeSkillsRoot, "claude-p-watch", "SKILL.md"),
      "utf8",
    );
    if (!watchSkillText.includes("Watch is enabled by default for this skill.")) {
      process.stderr.write("unexpected claude-p-watch contents\n");
      process.exit(1);
    }

    writeTurnCompleted("explicit skill allowlist ok");
    process.exit(0);
  }

  if (mode === "run_auth_failed") {
    writeFileFixture("run-auth-failed.jsonl");
    process.stderr.write("401 unauthorized\n");
    process.exit(1);
  }

  if (mode === "run_bad_jsonl") {
    writeFileFixture("run-bad-jsonl.txt");
    process.exit(0);
  }

  writeFileFixture("run-ok.jsonl");
  process.exit(0);
}

process.stderr.write(`unsupported fixture invocation: ${args.join(" ")}\n`);
process.exit(1);
